{
  "name": "@routr/ctl",
  "version": "2.13.17",
  "description": "Routr Command-Line Tool",
  "author": "Pedro Sanders <psanders@fonoster.com>",
  "bin": {
    "rctl": "./bin/run"
  },
  "homepage": "https://github.com/fonoster/routr#readme",
  "license": "MIT",
  "main": "dist/index.js",
  "repository": "https://github.com/fonoster/routr",
  "files": [
    "/bin",
    "/dist",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oclif/core": "^1.24.0",
    "@oclif/plugin-autocomplete": "^1.3.10",
    "@oclif/plugin-help": "^5",
    "@oclif/plugin-plugins": "^2.1.12",
    "@oclif/plugin-warn-if-update-available": "^2.0.19",
    "@routr/common": "^2.13.17",
    "@routr/sdk": "^2.13.17",
    "figlet": "^1.9.4",
    "fuzzy-search": "^3.2.1",
    "inquirer": "^8.2.7",
    "inquirer-autocomplete-prompt": "^2.0.1",
    "moment": "^2.29.4",
    "prettyjson": "^1.2.5"
  },
  "devDependencies": {
    "@oclif/test": "^2.2.20",
    "@types/chai": "^4.2.11",
    "@types/figlet": "^1.7.0",
    "@types/fuzzy-search": "^2.1.2",
    "@types/inquirer": "^8.2.12",
    "@types/inquirer-autocomplete-prompt": "^2.0.2",
    "@types/mocha": "^8.2.3",
    "@types/node": "^24.10.4",
    "@types/prettyjson": "^0.0.30",
    "chai": "^4",
    "mocha": "^11.7.5",
    "oclif": "^3.16.0",
    "shx": "^0.3.3",
    "ts-node": "^10.9.1",
    "tslib": "^2.4.1",
    "typescript": "^5.9.3"
  },
  "oclif": {
    "bin": "rctl",
    "dirname": "rctl",
    "commands": "./dist/commands",
    "helpClass": "./dist/help",
    "plugins": [
      "@oclif/plugin-plugins",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-autocomplete"
    ],
    "warn-if-update-available": {
      "timeoutInDays": 1,
      "message": "<%= config.name %> update available from <%= chalk.greenBright(config.version) %> to <%= chalk.greenBright(latest) %>."
    },
    "topicSeparator": " ",
    "repositoryPrefix": "https://github.com/fonoster/routr/blob/v<%= config.version %>/mods/ctl/<%= commandPath.replaceAll('dist/', 'src/') %>"
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b --force",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "yarn build && oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "bugs": "https://github.com/https://github.com/fonoster/routr/https://github.com/fonoster/routr/issues",
  "keywords": [
    "oclif"
  ],
  "types": "dist/index.d.ts",
  "gitHead": "7f681a3795686779da96692ca70ea759b381e371"
}
